{
  "name": "cliniflow-backend",
  "version": "1.0.0",
  "description": "Cliniflow API — entry is index.cjs in this folder only (never ../index.cjs or server_OLD).",
  "type": "commonjs",
  "main": "index.cjs",
  "scripts": {
    "start": "node index.cjs",
    "dev": "node index.cjs",
    "migrate:clinic-coords": "node scripts/migrate-clinic-coordinates.cjs",
    "migrate:clinic-coords:dry": "node scripts/migrate-clinic-coordinates.cjs --dry-run",
    "sim:coordinator:seed": "node scripts/seed-coordinator-simulation.cjs",
    "sim:coordinator:clear": "node scripts/clear-coordinator-simulation.cjs",
    "verify:schema": "node scripts/verify-supabase-schema.cjs --strict",
    "verify:rollout:http": "node scripts/verify-rollout-http.cjs",
    "verify:sim-guards": "node scripts/verify-simulation-guards.cjs",
    "verify:pre-rollout": "node scripts/verify-pre-rollout.cjs",
    "verify:booking-scenarios": "node scripts/verify-booking-scenarios.cjs",
    "verify:appointment-reliability": "node scripts/appointment-reliability-suite.cjs",
    "diagnose:booking-calendar": "node scripts/diagnose-booking-calendar.cjs",
    "netlify:deploy": "netlify deploy --dir=public --prod"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@supabase/supabase-js": "^2.39.0",
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow/tfjs-node": "4.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  }
}
