# Copy to `.env` in your Expo project root (same folder as app.json).
# Restart Metro after editing: `npx expo start -c`

# Backend (your machine’s LAN IP when testing on a real phone — same subnet as Expo device)
EXPO_PUBLIC_API_URL=http://172.20.10.2:3000

# Optional: onboarding / find-clinic HTML (defaults to EXPO_PUBLIC_API_URL if omitted)
EXPO_PUBLIC_CLINIC_WEB_ORIGIN=http://172.20.10.2:3000

# While debugging: mobile/lib/apiConfig.js FORCE_FIXED_API_BASE=true ignores .env — set false after verifying logs.
